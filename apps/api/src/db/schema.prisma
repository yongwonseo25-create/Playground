generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Artifact {
  id                        String           @id @default(cuid())
  workspaceId               String           @map("workspace_id")
  externalId                String?          @unique @map("external_id")
  title                     String?
  content                   String           @db.Text
  contentFormat             String           @map("content_format")
  artifactKind              String           @map("artifact_kind")
  destinationKey            String?          @map("destination_key")
  recipientKey              String?          @map("recipient_key")
  taskKey                   String?          @map("task_key")
  structureOutline          String           @map("structure_outline") @db.Text
  metadataJson              String           @map("metadata") @db.Text
  createdAt                 DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  sourceSignatures          StyleSignature[] @relation("SignatureSourceArtifact")
  primaryStyleEvents        StyleEvent[]     @relation("PrimaryArtifactEvent")
  generatedDraftStyleEvents StyleEvent[]     @relation("GeneratedDraftArtifactEvent")
  finalStyleEvents          StyleEvent[]     @relation("FinalArtifactEvent")
  sourceReferenceEdges      ReferenceEdge[]  @relation("ReferenceEdgeSource")
  targetReferenceEdges      ReferenceEdge[]  @relation("ReferenceEdgeTarget")

  @@index([workspaceId])
  @@index([workspaceId, artifactKind])
  @@map("artifacts")
}

model StyleSignature {
  id                  String           @id @default(cuid())
  workspaceId         String           @map("workspace_id")
  scopeType           String           @map("scope_type")
  scopeKey            String           @map("scope_key")
  destinationKey      String?          @map("destination_key")
  recipientKey        String?          @map("recipient_key")
  taskKey             String?          @map("task_key")
  versionNo           Int              @default(1) @map("version_no")
  occVersion          Int              @default(1) @map("occ_version")
  isCurrent           Boolean          @default(true) @map("is_current")
  signalCount         Int              @default(0) @map("signal_count")
  confidenceScore     Float            @default(0) @map("confidence_score")
  traitsJson          String           @map("traits_json") @db.Text
  sourceArtifactId    String?          @map("source_artifact_id")
  previousSignatureId String?          @map("previous_signature_id")
  supersededAt        DateTime?        @map("superseded_at") @db.Timestamptz(6)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  sourceArtifact      Artifact?        @relation("SignatureSourceArtifact", fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  previousSignature   StyleSignature?  @relation("StyleSignatureVersionChain", fields: [previousSignatureId], references: [id], onDelete: SetNull)
  nextSignatures      StyleSignature[] @relation("StyleSignatureVersionChain")
  styleEvents         StyleEvent[]

  @@unique([workspaceId, scopeType, scopeKey, versionNo])
  @@index([workspaceId, scopeType, scopeKey, isCurrent])
  @@index([destinationKey])
  @@index([recipientKey])
  @@index([taskKey])
  @@map("style_signatures")
}

model StyleEvent {
  id                       String          @id @default(cuid())
  workspaceId              String          @map("workspace_id")
  eventType                String          @map("event_type")
  artifactId               String?         @map("artifact_id")
  generatedDraftArtifactId String?         @map("generated_draft_artifact_id")
  finalArtifactId          String?         @map("final_artifact_id")
  signatureId              String?         @map("signature_id")
  diffSummary              String?         @map("diff_summary") @db.Text
  payloadSnapshotInline    String?         @map("payload_snapshot_inline") @db.Text
  payloadSnapshotUri       String?         @map("payload_snapshot_uri")
  payloadSnapshotSha256    String          @map("payload_snapshot_sha256")
  payloadSnapshotBytes     Int             @map("payload_snapshot_bytes")
  createdAt                DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  artifact                 Artifact?       @relation("PrimaryArtifactEvent", fields: [artifactId], references: [id], onDelete: SetNull)
  generatedDraftArtifact   Artifact?       @relation("GeneratedDraftArtifactEvent", fields: [generatedDraftArtifactId], references: [id], onDelete: SetNull)
  finalArtifact            Artifact?       @relation("FinalArtifactEvent", fields: [finalArtifactId], references: [id], onDelete: SetNull)
  signature                StyleSignature? @relation(fields: [signatureId], references: [id], onDelete: SetNull)

  @@index([workspaceId, eventType])
  @@index([artifactId])
  @@index([signatureId])
  @@map("style_events")
}

model ReferenceEdge {
  id               String   @id @default(cuid())
  sourceArtifactId String   @map("source_artifact_id")
  targetArtifactId String   @map("target_artifact_id")
  edgeType         String   @map("edge_type")
  weight           Float
  rationale        String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  sourceArtifact   Artifact @relation("ReferenceEdgeSource", fields: [sourceArtifactId], references: [id], onDelete: Cascade)
  targetArtifact   Artifact @relation("ReferenceEdgeTarget", fields: [targetArtifactId], references: [id], onDelete: Cascade)

  @@index([sourceArtifactId])
  @@index([targetArtifactId])
  @@map("reference_edges")
}

model BillingAccount {
  uid             String   @id
  availableCredits Int      @default(0) @map("available_credits")
  pendingCredits   Int      @default(0) @map("pending_credits")
  deductedCredits  Int      @default(0) @map("deducted_credits")
  refundedCredits  Int      @default(0) @map("refunded_credits")
  occVersion       Int      @default(1) @map("occ_version")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  transactions     BillingTransaction[]

  @@map("billing_accounts")
}

model BillingTransaction {
  id                String          @id @default(cuid())
  uid               String
  clientRequestId   String          @unique @map("client_request_id")
  costCredits       Int             @map("cost_credits")
  outputType        String          @map("output_type")
  promptPreview     String          @map("prompt_preview") @db.Text
  status            String
  providerName      String?         @map("provider_name")
  providerModel     String?         @map("provider_model")
  providerLatencyMs Int?            @map("provider_latency_ms")
  outputText        String?         @map("output_text") @db.Text
  providerUsageJson String?         @map("provider_usage_json") @db.Text
  secretVersion     String?         @map("secret_version")
  lastError         String?         @map("last_error") @db.Text
  expiresAt         DateTime        @map("expires_at") @db.Timestamptz(6)
  heartbeatAt       DateTime?       @map("heartbeat_at") @db.Timestamptz(6)
  reservedAt        DateTime        @default(now()) @map("reserved_at") @db.Timestamptz(6)
  executingAt       DateTime?       @map("executing_at") @db.Timestamptz(6)
  finalizedAt       DateTime?       @map("finalized_at") @db.Timestamptz(6)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  account           BillingAccount  @relation(fields: [uid], references: [uid], onDelete: Restrict)

  @@index([uid, status])
  @@index([status, expiresAt])
  @@map("billing_transactions")
}

model OutboxMessage {
  id                 String    @id @default(cuid())
  topic              String
  aggregateType      String    @map("aggregate_type")
  aggregateId        String    @map("aggregate_id")
  idempotencyKey     String    @unique @map("idempotency_key")
  status             String    @default("pending")
  payloadInline      String?   @map("payload_inline") @db.Text
  payloadUri         String?   @map("payload_uri")
  payloadSha256      String    @map("payload_sha256")
  payloadBytes       Int       @map("payload_bytes")
  availableAt        DateTime  @default(now()) @map("available_at") @db.Timestamptz(6)
  publishedAt        DateTime? @map("published_at") @db.Timestamptz(6)
  attempts           Int       @default(0)
  lastError          String?   @map("last_error") @db.Text
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, availableAt])
  @@map("outbox_messages")
}
