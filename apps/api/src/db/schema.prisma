datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Provider {
  NOTION
  SLACK
  KAKAO
  EMAIL
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED_RETRYABLE
  FAILED_TERMINAL
  UNKNOWN
}

model Artifact {
  id                        String           @id @default(cuid())
  workspaceId               String           @map("workspace_id")
  externalId                String?          @unique @map("external_id")
  title                     String?
  content                   String
  contentFormat             String           @map("content_format")
  artifactKind              String           @map("artifact_kind")
  destinationKey            String?          @map("destination_key")
  recipientKey              String?          @map("recipient_key")
  taskKey                   String?          @map("task_key")
  structureOutline          String           @map("structure_outline")
  metadataJson              String           @map("metadata")
  createdAt                 DateTime         @default(now()) @map("created_at")
  updatedAt                 DateTime         @updatedAt @map("updated_at")
  sourceSignatures          StyleSignature[] @relation("SignatureSourceArtifact")
  primaryStyleEvents        StyleEvent[]     @relation("PrimaryArtifactEvent")
  generatedDraftStyleEvents StyleEvent[]    @relation("GeneratedDraftArtifactEvent")
  finalStyleEvents          StyleEvent[]     @relation("FinalArtifactEvent")
  sourceReferenceEdges      ReferenceEdge[]  @relation("ReferenceEdgeSource")
  targetReferenceEdges      ReferenceEdge[]  @relation("ReferenceEdgeTarget")

  @@index([workspaceId])
  @@index([workspaceId, artifactKind])
  @@map("artifacts")
}

model StyleSignature {
  id               String    @id @default(cuid())
  workspaceId      String    @map("workspace_id")
  scopeType        String    @map("scope_type")
  scopeKey         String    @map("scope_key")
  destinationKey   String?   @map("destination_key")
  recipientKey     String?   @map("recipient_key")
  taskKey          String?   @map("task_key")
  signatureVersion Int       @default(1) @map("signature_version")
  signalCount      Int       @default(0) @map("signal_count")
  confidenceScore  Float     @default(0) @map("confidence_score")
  traitsJson       String    @map("traits_json")
  sourceArtifactId String?   @map("source_artifact_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  sourceArtifact   Artifact? @relation("SignatureSourceArtifact", fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  styleEvents      StyleEvent[]

  @@unique([workspaceId, scopeType, scopeKey])
  @@index([workspaceId, scopeType])
  @@index([destinationKey])
  @@index([recipientKey])
  @@index([taskKey])
  @@map("style_signatures")
}

model StyleEvent {
  id                       String          @id @default(cuid())
  workspaceId              String          @map("workspace_id")
  eventType                String          @map("event_type")
  artifactId               String?         @map("artifact_id")
  generatedDraftArtifactId String?         @map("generated_draft_artifact_id")
  finalArtifactId          String?         @map("final_artifact_id")
  signatureId              String?         @map("signature_id")
  diffSummary              String?         @map("diff_summary")
  payloadSnapshot          String          @map("payload_snapshot")
  createdAt                DateTime        @default(now()) @map("created_at")
  artifact                 Artifact?       @relation("PrimaryArtifactEvent", fields: [artifactId], references: [id], onDelete: SetNull)
  generatedDraftArtifact   Artifact?       @relation("GeneratedDraftArtifactEvent", fields: [generatedDraftArtifactId], references: [id], onDelete: SetNull)
  finalArtifact            Artifact?       @relation("FinalArtifactEvent", fields: [finalArtifactId], references: [id], onDelete: SetNull)
  signature                StyleSignature? @relation(fields: [signatureId], references: [id], onDelete: SetNull)

  @@index([workspaceId, eventType])
  @@index([artifactId])
  @@index([signatureId])
  @@map("style_events")
}

model ReferenceEdge {
  id               String   @id @default(cuid())
  sourceArtifactId String   @map("source_artifact_id")
  targetArtifactId String   @map("target_artifact_id")
  edgeType         String   @map("edge_type")
  weight           Float
  rationale        String?
  createdAt        DateTime @default(now()) @map("created_at")
  sourceArtifact   Artifact @relation("ReferenceEdgeSource", fields: [sourceArtifactId], references: [id], onDelete: Cascade)
  targetArtifact   Artifact @relation("ReferenceEdgeTarget", fields: [targetArtifactId], references: [id], onDelete: Cascade)

  @@index([sourceArtifactId])
  @@index([targetArtifactId])
  @@map("reference_edges")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  userIntegrations UserIntegration[]
  deliveryJobs     DeliveryJob[]

  @@map("users")
}

model UserIntegration {
  id                  String     @id @default(cuid())
  userId              String     @map("user_id")
  workspaceId         String     @unique @map("workspace_id")
  notionWorkspaceId   String?    @map("notion_workspace_id")
  notionWorkspaceName String?    @map("notion_workspace_name")
  accessTokenEnc      String     @map("access_token_enc")
  refreshTokenEnc     String?    @map("refresh_token_enc")
  tokenExpiresAt      DateTime?  @map("token_expires_at")
  botId               String?    @map("bot_id")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryJobs        DeliveryJob[]

  @@index([workspaceId])
  @@index([userId])
  @@map("user_integrations")
}

model ExecutionRequest {
  id              String         @id @default(cuid())
  workspaceId     String         @map("workspace_id")
  userId          String?        @map("user_id")
  artifactKind    String         @map("artifact_kind")
  promptContent   String         @map("prompt_content")
  metadataJson    String?        @map("metadata")
  status          String         @default("PENDING")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  deliveryJobs    DeliveryJob[]

  @@index([workspaceId])
  @@index([userId])
  @@map("execution_requests")
}

model DeliveryJob {
  id              String         @id @default(uuid())
  requestId       String         @map("request_id")
  executionRequestId String?     @map("execution_request_id")
  provider        Provider
  recipientKey    String         @map("recipient_key")
  idempotencyKey  String         @unique @map("idempotency_key")
  status          DeliveryStatus @default(PENDING)
  attemptCount    Int            @default(0) @map("attempt_count")
  lastErrorCode   String?        @map("last_error_code")
  payload         Json
  
  userId          String?        @map("user_id")
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  userIntegrationId String?      @map("user_integration_id")
  userIntegration UserIntegration? @relation(fields: [userIntegrationId], references: [id], onDelete: SetNull)
  workspaceId     String?        @map("workspace_id")

  executionRequest ExecutionRequest? @relation(fields: [executionRequestId], references: [id], onDelete: Cascade)

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  scheduledAt     DateTime?      @map("scheduled_at")
  startedAt       DateTime?      @map("started_at")
  completedAt     DateTime?      @map("completed_at")

  @@index([status, scheduledAt])
  @@index([requestId])
  @@index([executionRequestId])
  @@map("delivery_jobs")
}
