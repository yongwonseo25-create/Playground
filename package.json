{
  "name": "voxera-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https --hostname localhost --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "db:ssce:generate": "prisma generate --schema apps/api/src/db/schema.prisma",
    "db:ssce:migrate": "node --experimental-strip-types --experimental-specifier-resolution=node apps/api/src/db/run-ssce-migrations.ts",
    "test": "playwright test tests/e2e/env-core.spec.ts tests/e2e/backend-reliability.spec.ts tests/e2e/dual-stt-router.spec.ts -c tests/playwright.env-core.config.ts && corepack pnpm test:ssce",
    "test:billing-mcp": "playwright test tests/e2e/billing-mcp.spec.ts -c tests/playwright.env-core.config.ts",
    "test:ssce": "corepack pnpm db:ssce:generate && corepack pnpm db:ssce:migrate && vitest run apps/api/src/routes/ssce-api.spec.ts",
    "test:ssce:watch": "vitest apps/api/src/routes/ssce-api.spec.ts",
    "test:e2e": "playwright test tests/e2e/voice-capture-flow.spec.ts tests/e2e/voice-runtime-live.spec.ts tests/e2e/voice-cutoff-ui.spec.ts -c tests/playwright.config.ts",
    "test:e2e:routing": "playwright test tests/e2e/voice-stt-routing-live.spec.ts -c tests/playwright.routing.config.ts",
    "mcp:reviewer": "node --experimental-strip-types scripts/mcp-reviewer-client.ts",
    "mcp:mock-bridge": "node --experimental-strip-types scripts/mock-mcp-bridge.ts",
    "verify:real-output": "node --experimental-strip-types scripts/verify-generate-output-real.ts"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "@prisma/client": "^6.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-visually-hidden": "^1.1.0",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.4.49",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4",
    "ws": "^8.19.0"
  }
}
