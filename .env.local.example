NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_WSS_URL=ws://localhost:8787/voice-session
NEXT_PUBLIC_WEBHOOK_URL=http://localhost:8080/api/webhook
MAKE_WEBHOOK_URL=http://localhost:8080/api/webhook
MAKE_WEBHOOK_SECRET=replace-with-secret
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIRESTORE_DATABASE_ID=(default)
GOOGLE_AI_STUDIO_API_KEY_SECRET=projects/your-project/secrets/google-ai-studio-api-key/versions/latest
